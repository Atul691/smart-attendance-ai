<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Edit Student</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

<style>

body{

    background:#f4f6f9;

}

.card{

    max-width:700px;
    margin:auto;
    margin-top:50px;
    border:none;
    border-radius:15px;
    box-shadow:0 0 15px rgba(0,0,0,.15);

}

</style>

</head>

<body>

<div class="card p-4">

<h2 class="text-center">

✏️ Edit Student

</h2>

<hr>

<form action="/api/students/update/<%= student.id %>" method="POST">

<div class="mb-3">

<label>ERP ID</label>

<input
type="text"
name="erp_id"
class="form-control"
value="<%= student.erp_id %>"
required>

</div>

<div class="mb-3">

<label>Name</label>

<input
type="text"
name="name"
class="form-control"
value="<%= student.name %>"
required>

</div>

<div class="mb-3">

<label>Email</label>

<input
type="email"
name="email"
class="form-control"
value="<%= student.email %>"
required>

</div>

<div class="mb-3">

<label>Department</label>

<input
type="text"
name="department"
class="form-control"
value="<%= student.department %>"
required>

</div>

<div class="mb-3">

<label>Semester</label>

<input
type="text"
name="semester"
class="form-control"
value="<%= student.semester %>"
required>

</div>

<div class="mb-3">

<label>Status</label>

<select
name="approval_status"
class="form-select">

<option
value="approved"
<%= student.approval_status=="approved" ? "selected" : "" %>>

Approved

</option>

<option
value="pending"
<%= student.approval_status=="pending" ? "selected" : "" %>>

Pending

</option>

</select>

</div>

<div class="d-flex justify-content-between">

<a
href="/api/students/list"
class="btn btn-secondary">

⬅ Back

</a>

<button
type="submit"
class="btn btn-success">

💾 Update Student

</button>

</div>

</form>

</div>

</body>

</html>