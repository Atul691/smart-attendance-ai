<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Admin Dashboard</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

<style>

body{

background:#f5f7fb;

}

.card{

border:none;

border-radius:15px;

box-shadow:0 0 15px rgba(0,0,0,.12);

transition:.3s;

}

.card:hover{

transform:translateY(-5px);

}

.number{

font-size:40px;

font-weight:bold;

color:#198754;

}

</style>

</head>

<body>

<div class="container mt-5">

<h2 class="mb-4">

🎓 Smart Attendance Admin Dashboard

</h2>

<div class="row">

<div class="col-md-3">

<div class="card p-4 text-center">

<h5>Total Students</h5>

<div
id="totalStudents"
class="number">

0

</div>

</div>

</div>

<div class="col-md-3">

<div class="card p-4 text-center">

<h5>Total Teachers</h5>

<div
id="totalTeachers"
class="number">

0

</div>

</div>

</div>

<div class="col-md-3">

<div class="card p-4 text-center">

<h5>Present Today</h5>

<div
id="presentToday"
class="number">

0

</div>

</div>

</div>

<div class="col-md-3">

<div class="card p-4 text-center">

<h5>Attendance %</h5>

<div
id="attendancePercentage"
class="number">

0%

</div>

</div>

</div>

</div>

<hr class="my-5">

<div class="row">

<div class="col-md-8">

<div class="card p-4">

<h4>

📅 Recent Attendance

</h4>

<table class="table">

<thead>

<tr>

<th>Name</th>

<th>Time</th>

<th>Status</th>

</tr>

</thead>

<tbody id="recentAttendance">

</tbody>

</table>

</div>

</div>

<div class="col-md-4">

<div class="card p-4">

<h4>

⚡ Quick Menu

</h4>

<div class="d-grid gap-3">

<a
href="/api/students/list"
class="btn btn-success">

Student Management

</a>

<a
href="/attendance"
class="btn btn-primary">

Live Attendance

</a>

<a
href="/attendance/report"
class="btn btn-dark">

Attendance Report

</a>

</div>

</div>

</div>

</div>

</div>

</body>

</html>