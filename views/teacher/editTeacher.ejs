<!DOCTYPE html>
<html>

<head>

<title>Edit Teacher</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

<div class="card p-4">

<h2>Edit Teacher</h2>

<form
action="/teacher/update/<%= teacher.id %>"
method="POST">

<div class="mb-3">

<label>Teacher ID</label>

<input
class="form-control"
name="teacher_id"
value="<%= teacher.teacher_id %>">

</div>

<div class="mb-3">

<label>Name</label>

<input
class="form-control"
name="name"
value="<%= teacher.name %>">

</div>

<div class="mb-3">

<label>Email</label>

<input
class="form-control"
name="email"
value="<%= teacher.email %>">

</div>

<div class="mb-3">

<label>Department</label>

<input
class="form-control"
name="department"
value="<%= teacher.department %>">

</div>

<div class="mb-3">

<label>Designation</label>

<input
class="form-control"
name="designation"
value="<%= teacher.designation %>">

</div>

<div class="mb-3">

<label>Phone</label>

<input
class="form-control"
name="phone"
value="<%= teacher.phone %>">

</div>

<button
class="btn btn-success">

Update Teacher

</button>

</form>

</div>

</div>

</body>

</html>