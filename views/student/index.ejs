<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Student Management</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

<style>

body{

    background:#f4f6f9;

}

.card{

    border:none;
    border-radius:15px;
    box-shadow:0 0 15px rgba(0,0,0,.1);

}

.table th{

    background:#198754;
    color:white;

}

.badge{

    font-size:14px;

}

</style>

</head>

<body>

<div class="container mt-5">

<div class="card p-4">

<div class="d-flex justify-content-between align-items-center">

<h2>🎓 Student Management</h2>

<a
href="/register"
class="btn btn-success">

+ Add Student

</a>

</div>

<hr>

<div class="row mb-3">

<div class="col-md-6">

<input

id="searchStudent"

class="form-control"

type="text"

placeholder="🔍 Search by Name or ERP ID"

>

</div>

<div class="col-md-3">

<select
id="statusFilter"
class="form-select">

<option value="all">

All Students

</option>

<option value="approved">

Approved

</option>

<option value="pending">

Pending

</option>

</select>

</div>

</div>

<div class="table-responsive">

<table
id="studentTable"
class="table table-bordered table-hover">

<thead>

<tr>

<th>ID</th>
<th>ERP ID</th>
<th>Name</th>
<th>Department</th>
<th>Status</th>
<th>Actions</th>

</tr>

</thead>

<tbody>

<% students.forEach(student=>{ %>

<tr>

<td><%= student.id %></td>

<td><%= student.erp_id %></td>

<td><%= student.name %></td>

<td><%= student.department %></td>

<td>

<% if(student.approval_status==="approved"){ %>

<span class="badge bg-success">

Approved

</span>

<% }else{ %>

<span class="badge bg-warning text-dark">

Pending

</span>

<% } %>

</td>

<td>

<a
href="/api/students/view/<%= student.id %>"
class="btn btn-primary btn-sm">

View

</a>

<a
href="/api/students/edit/<%= student.id %>"
class="btn btn-warning btn-sm">

Edit

</a>

<a
href="/api/students/delete/<%= student.id %>"
class="btn btn-danger btn-sm"
onclick="return confirm('Are you sure you want to delete this student?')">

🗑 Delete

</a>

</td>

</tr>

<% }) %>

</tbody>

</table>
<nav class="mt-4">

<ul
id="pagination"
class="pagination justify-content-center">

</ul>

</nav>
</div>

</div>

</div>

<script>

const searchInput =
document.getElementById("searchStudent");

const statusFilter =
document.getElementById("statusFilter");

searchInput.addEventListener(
"keyup",
filterTable
);

statusFilter.addEventListener(
"change",
filterTable
);

function filterTable(){

    const search =
        searchInput.value.toLowerCase();

    const status =
        statusFilter.value;

    const rows =
        document.querySelectorAll("#studentTable tbody tr");

    rows.forEach(row=>{

        const text =
            row.innerText.toLowerCase();

        const rowStatus =
            row.cells[4]
            .innerText
            .trim()
            .toLowerCase();

        const matchSearch =
            text.includes(search);

        const matchStatus =
            status==="all" ||
            rowStatus===status;

        row.style.display =
            (matchSearch && matchStatus)
            ? ""
            : "none";

    });

    // Pagination refresh
    showPage(1);

}

// =======================
// Pagination
// =======================

const rowsPerPage = 10;

let currentPage = 1;

function showPage(page){

    const rows =
        document.querySelectorAll("#studentTable tbody tr");

    const visibleRows =
        Array.from(rows).filter(r=>r.style.display!="none");

    const totalPages =
        Math.ceil(visibleRows.length / rowsPerPage);

    currentPage = page;

    rows.forEach(r=>{

        if(r.style.display!="none"){
            r.style.display="none";
        }

    });

    visibleRows.forEach((row,index)=>{

        if(
            index >= (page-1)*rowsPerPage &&
            index < page*rowsPerPage
        ){
            row.style.display="";
        }

    });

    renderPagination(totalPages);

}

function renderPagination(totalPages){

    const pagination =
        document.getElementById("pagination");

    pagination.innerHTML="";

    for(let i=1;i<=totalPages;i++){

        const li =
            document.createElement("li");

        li.className =
            `page-item ${i===currentPage?"active":""}`;

        li.innerHTML = `
            <a class="page-link" href="#">
                ${i}
            </a>
        `;

        li.onclick=function(e){

            e.preventDefault();

            showPage(i);

        };

        pagination.appendChild(li);

    }

}

// First Load
showPage(1);

</script>

</body>

</html>