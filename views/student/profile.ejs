<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Student Profile</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

<style>

body{

    background:#f4f6f9;

}

.card{

    border:none;
    border-radius:15px;
    box-shadow:0 0 15px rgba(0,0,0,.1);

}

.profile-img{

    width:150px;
    height:150px;
    border-radius:50%;
    object-fit:cover;
    border:4px solid #198754;

}

.table th{

    background:#198754;
    color:white;

}

</style>

</head>

<body>

<div class="container mt-5">

<div class="card p-4">

<div class="row">

<div class="col-md-3 text-center">

<img

src="<%= student.photo_url %>"

class="profile-img"

alt="Student Photo">

</div>

<div class="col-md-9">

<h2>

<%= student.name %>

</h2>

<hr>

<p><strong>ERP ID :</strong> <%= student.erp_id %></p>

<p><strong>Email :</strong> <%= student.email %></p>

<p><strong>Department :</strong> <%= student.department %></p>

<p><strong>Semester :</strong> <%= student.semester %></p>

<p>

<strong>Total Present :</strong>
<p>

<strong>Total Absent :</strong>

<span class="badge bg-danger">

<%= absent %>

</span>

</p>

<p>

<strong>Attendance % :</strong>

<span class="badge bg-primary">

<%= percentage %>%

</span>

</p>

<% if(lastAttendance){ %>

<p>

<strong>Last Attendance :</strong>

<%= lastAttendance.attendance_date %>

<%= lastAttendance.attendance_time %>

</p>

<% } %>

<span class="badge bg-success">

<%= present %>

</span>

</p>

</div>

</div>

<hr>

<h3>

📅 Attendance History

</h3>

<table class="table table-bordered">

<thead>

<tr>

<th>Date</th>
<th>Time</th>
<th>Status</th>

</tr>

</thead>

<tbody>

<% attendance.forEach(item=>{ %>

<tr>

<td>

<%= item.attendance_date %>

</td>

<td>

<%= item.attendance_time %>

</td>

<td>

<span class="badge bg-success">

<%= item.status %>

</span>

</td>

</tr>

<% }) %>

</tbody>

</table>

<div class="mt-4">

<a
href="/api/students/pdf/<%= student.id %>"
class="btn btn-success">

📄 Download PDF

</a>

<a
href="/teacher/students"
class="btn btn-secondary">

⬅ Back

</a>

</div>

</div>

</body>

</html>