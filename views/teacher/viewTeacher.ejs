<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1">

<title>Teacher Details</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

<div class="card p-4">

<h2>

👨‍🏫 Teacher Details

</h2>

<hr>

<table class="table table-bordered">

<tr>

<th width="220">

Teacher ID

</th>

<td>

<%= teacher.teacher_id %>

</td>

</tr>

<tr>

<th>

Name

</th>

<td>

<%= teacher.name %>

</td>

</tr>

<tr>

<th>

Email

</th>

<td>

<%= teacher.email %>

</td>

</tr>

<tr>

<th>

Department

</th>

<td>

<%= teacher.department %>

</td>

</tr>

<tr>

<th>

Designation

</th>

<td>

<%= teacher.designation %>

</td>

</tr>

<tr>

<th>

Phone

</th>

<td>

<%= teacher.phone %>

</td>

</tr>

</table>

<a
href="/teacher/list"
class="btn btn-success">

⬅ Back

</a>

</div>

</div>

</body>

</html>