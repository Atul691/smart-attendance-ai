<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Student Profile</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

<style>

body{

    background:#f4f6f9;

}

.card{

    max-width:700px;

    margin:auto;

    margin-top:50px;

    border:none;

    border-radius:15px;

    box-shadow:0 0 15px rgba(0,0,0,.15);

}

.table td{

    font-size:18px;

    padding:15px;

}

</style>

</head>

<body>

<div class="container">

<div class="card p-4">

<h2 class="text-center">

🎓 Student Profile

</h2>

<hr>

<table class="table table-bordered">

<tr>

<th width="35%">

Student ID

</th>

<td>

<%= student.id %>

</td>

</tr>

<tr>

<th>

ERP ID

</th>

<td>

<%= student.erp_id %>

</td>

</tr>

<tr>

<th>

Name

</th>

<td>

<%= student.name %>

</td>

</tr>

<tr>

<th>

Email

</th>

<td>

<%= student.email %>

</td>

</tr>

<tr>

<th>

Department

</th>

<td>

<%= student.department %>

</td>

</tr>

<tr>

<th>

Semester

</th>

<td>

<%= student.semester %>

</td>

</tr>

<tr>

<th>

Status

</th>

<td>

<% if(student.approval_status==="approved"){ %>

<span class="badge bg-success">

Approved

</span>

<% }else{ %>

<span class="badge bg-warning text-dark">

Pending

</span>

<% } %>

</td>

</tr>

</table>

<div class="d-flex justify-content-between mt-3">

<a
href="/api/students/list"
class="btn btn-secondary">

⬅ Back

</a>

<div>

<a
href="/api/students/edit/<%= student.id %>"
class="btn btn-warning">

✏ Edit

</a>

<a
href="/api/students/delete/<%= student.id %>"
class="btn btn-danger"
onclick="return confirm('Delete this student?')">

🗑 Delete

</a>

</div>

</div>

</div>

</div>

</body>

</html>