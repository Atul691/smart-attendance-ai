<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Smart Attendance AI Dashboard</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet"
/>

<link
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
rel="stylesheet"
/>

<style>

body{
    background:#f4f6f9;
    overflow-x:hidden;
}

.sidebar{
    min-height:100vh;
    background:#212529;
    color:white;
    padding:20px;
}

.sidebar h3{
    text-align:center;
}

.sidebar a{
    display:block;
    color:white;
    text-decoration:none;
    padding:12px;
    border-radius:8px;
    margin-bottom:10px;
    transition:.3s;
}

.sidebar a:hover{
    background:#343a40;
}

.top-card{
    border:none;
    border-radius:15px;
    box-shadow:0 4px 15px rgba(0,0,0,.1);
}

.card-icon{
    font-size:40px;
}

.dashboard-title{
    font-weight:bold;
}

.search-card{
    border:none;
    border-radius:15px;
    box-shadow:0 4px 15px rgba(0,0,0,.1);
}

</style>

</head>

<body>

<div class="container-fluid">

<div class="row">

<!-- Sidebar -->

<div class="col-md-3 col-lg-2 sidebar">

<h3>🎓 Smart Attendance</h3>

<hr>

<a href="/teacher/dashboard">
<i class="fas fa-chart-line"></i>
Dashboard
</a>

<a href="/teacher/pending">
<i class="fas fa-user-clock"></i>
Pending Students
</a>

<a href="/teacher/approved">
<i class="fas fa-user-check"></i>
Approved Students
</a>

<a href="#">
<i class="fas fa-calendar-check"></i>
Attendance Reports
</a>

</div>

<!-- Main Content -->

<div class="col-md-9 col-lg-10 p-4">

<h2 class="dashboard-title">
Teacher Dashboard
</h2>

<p>
Welcome to Smart Attendance AI System
</p>

<div class="text-end mb-3">

<a
href="/teacher/logout"
class="btn btn-danger">

🚪 Logout

</a>

</div>
<hr>

<div class="row mt-4">

<div class="col-md-6">

<div class="card p-3">

<h4>

📊 Attendance Summary

</h4>

<p>

Today's Attendance

</p>

<h2 id="todayAttendance">

0

</h2>

<p>

Total Attendance

</p>

<h2 id="totalAttendance">

0

</h2>

</div>

</div>

<div class="col-md-6">

<div class="card p-3">

<h4>

🏆 Top Regular Students

</h4>

<ul
id="topStudents"
class="list-group">

</ul>

</div>

</div>

</div>

<div class="row mt-4">

<div class="col-md-12">

<div class="card p-3">

<h4>

⚠ Students With Low Attendance

</h4>

<ul
id="lowAttendance"
class="list-group">

</ul>

</div>

</div>

</div>

<hr>
<div class="row g-4">

<!-- Total -->

<div class="col-md-4">

<div class="card top-card p-4">

<div class="d-flex justify-content-between">

<div>
<h5>Total Students</h5>

<h1>
<%= totalStudents %>
</h1>
</div>

<div class="card-icon">
👨‍🎓
</div>

</div>

</div>

</div>

<!-- Approved -->

<div class="col-md-4">

<div class="card top-card p-4">

<div class="d-flex justify-content-between">

<div>
<h5>Approved Students</h5>

<h1>
<%= approvedStudents %>
</h1>
</div>

<div class="card-icon">
✅
</div>

</div>

</div>

</div>

<!-- Pending -->

<div class="col-md-4">

<div class="card top-card p-4">

<div class="d-flex justify-content-between">

<div>
<h5>Pending Students</h5>

<h1>
<%= pendingStudents %>
</h1>
</div>

<div class="card-icon">
⏳
</div>

</div>

</div>

</div>

</div>

<br>

<!-- Quick Actions -->

<div class="card search-card p-4">

<h4>
Quick Actions
</h4>

<br>

<a
href="/teacher/pending"
class="btn btn-warning"
>
Pending Students
</a>

<a
href="/teacher/approved"
class="btn btn-success"
>
Approved Students
</a>

<hr>

<h4>
Search Student By ERP ID
</h4>

<form
action="/teacher/search"
method="GET"
>

<div class="input-group">

<input
type="text"
name="erp"
class="form-control"
placeholder="Enter ERP ID"
required
>

<button
type="submit"
class="btn btn-primary"
>
Search
</button>

</div>

</form>

</div>

<br>

<!-- Analytics -->

<div class="card search-card p-4">

<h4>
System Analytics
</h4>

<ul>

<li>
Total Registered Students :
<strong>
<%= totalStudents %>
</strong>
</li>

<li>
Approved Students :
<strong>
<%= approvedStudents %>
</strong>
</li>

<li>
Pending Students :
<strong>
<%= pendingStudents %>
</strong>
</li>

</ul>

</div>

</div>

</div>

</div>
<script>

async function loadAnalytics(){

    const response =
    await fetch("/teacher/analytics");

    const data =
    await response.json();

    document.getElementById("todayAttendance").innerHTML =
    data.todayAttendance;

    document.getElementById("totalAttendance").innerHTML =
    data.totalAttendance;

    const topList =
    document.getElementById("topStudents");

    topList.innerHTML="";

    data.topStudents.forEach(student=>{

        topList.innerHTML+=`

        <li class="list-group-item">

        ${student.name}
        (${student.present_days} Days)

        </li>

        `;

    });

    const lowList =
    document.getElementById("lowAttendance");

    lowList.innerHTML="";

    data.lowAttendance.forEach(student=>{

        lowList.innerHTML+=`

        <li class="list-group-item text-danger">

        ${student.name}
        (${student.present_days} Days)

        </li>

        `;

    });

}

loadAnalytics();

</script>

</body>
</html>